def _configure_stream_handler(logger: logging.Logger, handler_name: str, log_level: int,
                              formatter: logging.Formatter) -> None:
    """Configure or update StreamHandler for a logger.

    Checks if a StreamHandler with the given name already exists on the logger. If found, updates its level and formatter. If
    not found, creates a new one.

    Args:
        logger (logging.Logger): The logger to configure.
        handler_name (str): Name for the stream handler.
        log_level (int): Logging level (e.g., logging.INFO).
        formatter (logging.Formatter): Formatter instance (ColoredFormatter).
    """
    existing_handler = None
    for handler in logger.handlers:
        if isinstance(handler, StreamHandler) and handler.name == handler_name:
            existing_handler = handler
            break
    if existing_handler:
        existing_handler.setLevel(log_level)
        existing_handler.setFormatter(formatter)
    else:
        stream_handler = logging.StreamHandler()
        stream_handler.name = handler_name
        stream_handler.setLevel(log_level)
        stream_handler.setFormatter(formatter)
        logger.addHandler(stream_handler)


def get_logger(name: str = ROOT_LOGGER_NAME) -> logging.Logger:
    """Get the logger instance for linter_ignores_report.

    Args:
        name (str): Logger name. Defaults to ROOT_LOGGER_NAME ('linter_ignores_report').

    Returns:
        logging.Logger: The logger instance.
    """
    return logging.getLogger(name)


def setup_logging(disable_logging: bool = False, enable_debug: bool = False) -> None:
    """Configure logging for linter_ignores_report with colorized console output.

    Sets up the main logger with colorized console output. Debug mode provides detailed execution information about file
    scanning, pattern matching, and statistics calculation.

    Args:
        disable_logging (bool): If True, sets log level to CRITICAL (minimal logging). Defaults to False.
        enable_debug (bool): If True, sets log level to DEBUG for verbose output. Defaults to False.
    """
    log_level = logging.INFO
    if enable_debug and not disable_logging:
        log_level = logging.DEBUG
    elif disable_logging:
        log_level = logging.CRITICAL
    logger = logging.getLogger(ROOT_LOGGER_NAME)
    logger.setLevel(log_level)
    _configure_stream_handler(logger, STREAM_HANDLER_NAME, log_level, ColoredFormatter(LOG_FORMAT_COLORED, bold=True))
    if enable_debug:
        get_logger().debug('Debugging has been enabled.')


# #############################################################################################################################
# Data Structures
# #############################################################################################################################
class IgnoreOccurrence:  # pylint: disable=too-few-public-methods
    """Represents a single linter suppression occurrence in a Python file.

    Each instance captures one suppression comment found during file scanning, including its location, the tool being
    suppressed, the specific error codes (if any), and the full line of code for context.

    Args:
        file_path (Path): Absolute path to the file containing the suppression.
        display_path (str): Relative path for display in output.
        line_number (int): Line number where the suppression appears (1-indexed).
        tool (str): Name of the linter tool (e.g., 'noqa', 'type-ignore', 'pylint').
        error_codes (Sequence[str]): Sequence of error codes being suppressed. Contains ('<all>',) for bare suppressions without specific codes.
        line_content (str): The full line of code containing the suppression comment.
    """
    def __init__(self, file_path: Path, display_path: str, line_number: int, tool: str, error_codes: Sequence[str], line_content: str) -> None:
        self.file_path = file_path
        self.display_path = display_path
        self.line_number = line_number
        self.tool = tool
        self.error_codes = error_codes
        self.line_content = line_content.rstrip()


class Statistics:  # pylint: disable=too-few-public-methods
    """Container for statistical analysis of linter suppressions.

    Aggregates suppression data from all scanned files to provide comprehensive metrics including file counts, tool
    distribution, error code frequency, and per-file statistics. Used to generate detailed reports for code quality audits and
    refactoring planning.

    """
    def __init__(self) -> None:
        self.total_files_scanned: int = 0
        self.files_with_ignores: int = 0
        self.total_ignores: int = 0
        self.ignores_by_tool: dict[str, int] = defaultdict(int)
        self.ignores_by_error_code: dict[str, int] = defaultdict(int)
        self.ignores_per_file: dict[Path, int] = defaultdict(int)
        self.file_display_paths: dict[Path, str] = {}


# #############################################################################################################################
# File Discovery
# #############################################################################################################################
def _find_python_files(path: Path) -> list[Path]:
    """Find all Python files in the given path.

    For single files, validates .py extension and returns single-element list. For directories, recursively searches for all
    .py files using Path.rglob(). Prints warning to stderr and returns empty list if single file path does not have .py
    extension.

    Args:
        path (Path): Path to a file or directory. If file, returns single-item list. If directory, recursively finds
            all .py files using rglob('*.py').

    Returns:
        list[Path]: List of Path objects pointing to Python files, sorted alphabetically by full path.
    """
    if path.is_file():
        if path.suffix == '.py':
            return [path]
        print('Warning: %s is not a Python file (.py extension required)' % (path), file=sys.stderr)
        return []
    # Recursively find all .py files
    return sorted(path.rglob('*.py'))


# #############################################################################################################################
# Ignore Pattern Detection
# #############################################################################################################################
def _extract_ignore_info(line: str, line_number: int, file_path: Path, base_path: Path) -> list[IgnoreOccurrence]:
    """Extract linter suppression information from a single line of code.

    Searches the line for suppression comments matching patterns defined in IGNORE_PATTERNS. For each match, extracts the tool
    name and error codes (if specified). Bare suppressions without error codes are recorded as ('<all>',). Multiple suppression
    types on the same line (e.g., both # noqa and # type: ignore) result in multiple IgnoreOccurrence objects.

    Args:
        line (str): The line of code to analyze for suppression comments.
        line_number (int): Line number in the file (1-indexed) for occurrence tracking.
        file_path (Path): Absolute path to the file being analyzed for occurrence tracking.
        base_path (Path): Base search path for formatting relative file paths.

    Returns:
        list[IgnoreOccurrence]: List of IgnoreOccurrence objects found in the line (may be empty if no suppressions found).
    """
    occurrences: list[IgnoreOccurrence] = []
    display_path = _format_file_path(file_path, base_path)
    for tool, pattern in IGNORE_PATTERNS.items():
        match = pattern.search(line)
        if match:
            # Extract error codes if present
            error_codes_str = match.group(1) if match.lastindex and match.lastindex >= 1 else None
            error_codes: Sequence[str]
            if error_codes_str:
                # Split by comma and clean whitespace
                error_codes = [code.strip() for code in error_codes_str.split(',') if code.strip()]
            else:
                # No specific error codes (bare suppression)
                error_codes = ('<all>',)
            occurrences.append(IgnoreOccurrence(file_path, display_path, line_number, tool, error_codes, line))
    return occurrences


def _scan_file(file_path: Path, base_path: Path) -> list[IgnoreOccurrence]:
    """Scan a single Python file for linter suppression comments.

    Opens the file with UTF-8 encoding and processes each line sequentially, extracting suppression information via
    _extract_ignore_info(). Handles OSError and UnicodeDecodeError gracefully by printing warning to stderr and returning
    partial results.

    Args:
        file_path (Path): Path to the Python file to scan for suppression comments.
        base_path (Path): Base search path for formatting relative file paths.

    Returns:
        list[IgnoreOccurrence]: List of IgnoreOccurrence objects found in the file (empty list if file cannot be read or
            contains no suppressions).
    """
    occurrences: list[IgnoreOccurrence] = []
    try:
        with file_path.open('r', encoding='utf-8') as f:
            for line_number, line in enumerate(f, start=1):
                occurrences.extend(_extract_ignore_info(line, line_number, file_path, base_path))
    except (OSError, UnicodeDecodeError) as e:
        print('Warning: Could not read %s: %s' % (file_path, e), file=sys.stderr)
    return occurrences


def _scan_all_files(file_list: list[Path], base_path: Path) -> list[IgnoreOccurrence]:
    """Scan multiple Python files for linter suppression comments.

    Iterates through all provided file paths and aggregates suppression occurrences from each file. Uses _scan_file() for
    individual file processing.

    Args:
        file_list (list[Path]): List of Python file paths to scan for suppression comments.
        base_path (Path): Base search path for formatting relative file paths.

    Returns:
        list[IgnoreOccurrence]: List of all IgnoreOccurrence objects found across all files, aggregated from individual file scans.
    """
    all_occurrences: list[IgnoreOccurrence] = []
    for file_path in file_list:
        occurrences = _scan_file(file_path, base_path)
        all_occurrences.extend(occurrences)
    return all_occurrences


# #############################################################################################################################
# Statistics Calculation
# #############################################################################################################################
def _calculate_statistics(occurrences: list[IgnoreOccurrence], total_files: int) -> Statistics:
    """Calculate statistical metrics from collected suppression occurrences.

    Processes all occurrences to compute aggregated statistics including: total counts, distributions by tool and error code,
    per-file counts, and unique file tracking. Builds comprehensive metrics for report generation.

    Args:
        occurrences (list[IgnoreOccurrence]): List of all IgnoreOccurrence objects found during scanning.
        total_files (int): Total number of Python files scanned (for coverage calculation).

    Returns:
        Statistics: Statistics object containing computed metrics (file counts, tool distribution, error code frequency, per-file statistics).
    """
    stats = Statistics()
    stats.total_files_scanned = total_files
    stats.total_ignores = len(occurrences)
    # Track unique files with ignores
    files_with_ignores: set[Path] = set()
    for occurrence in occurrences:
        # Count by tool
        stats.ignores_by_tool[occurrence.tool] += 1
        # Count by error code
        for error_code in occurrence.error_codes:
            stats.ignores_by_error_code[error_code] += 1
        # Count per file
        stats.ignores_per_file[occurrence.file_path] += 1
        files_with_ignores.add(occurrence.file_path)
        # Map file_path to display_path
        if occurrence.file_path not in stats.file_display_paths:
            stats.file_display_paths[occurrence.file_path] = occurrence.display_path
    stats.files_with_ignores = len(files_with_ignores)
    return stats


