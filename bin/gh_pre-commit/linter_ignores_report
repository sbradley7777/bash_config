# #############################################################################################################################
def _format_section_header(section_name: str) -> str:
    """Format a section header with separator lines.

    Args:
        section_name (str): Name of the section to display.

    Returns:
        str: Formatted section header with 80-character separator lines.
    """
    separator = '#' * 80
    return '%s\n%s\n%s' % (separator, section_name, separator)


def _format_tool_name(tool: str) -> str:
    """Convert internal tool name to display-friendly format.

    Maps internal pattern keys to user-friendly display names for output formatting. Returns the original tool name if no
    mapping exists.

    Args:
        tool (str): Internal tool identifier from IGNORE_PATTERNS keys (e.g., 'noqa', 'type-ignore', 'pylint').

    Returns:
        str: Human-readable tool name for display (e.g., 'flake8', 'mypy', 'pylint'). Returns original tool name if not in mapping.
    """
    return {
        'noqa': 'flake8',
        'type-ignore': 'mypy',
        'pylint': 'pylint',
        'ruff-noqa': 'ruff',
        'refurb': 'refurb',
    }.get(tool, tool)


def _format_file_path(file_path: Path, base_path: Path) -> str:
    """Format file path as relative to the parent of the base search path.

    Converts absolute file paths to relative display paths that include the base directory name. This provides context about
    which directory was searched while keeping paths concise.

    Args:
        file_path (Path): Absolute path to the file to format.
        base_path (Path): Base search path (the -p argument value, resolved to absolute).

    Returns:
        str: Relative path string including the base directory name.

    Examples:
        >>> base = Path('/home/user/projects/myapp/src')
        >>> file = Path('/home/user/projects/myapp/src/utils/helper.py')
        >>> _format_file_path(file, base)
        'src/utils/helper.py'

    """
    try:
        # Get parent of base_path to make paths relative to it
        parent = base_path.parent
        # Make file_path relative to parent
        return str(file_path.relative_to(parent))
    except ValueError:
        # If file_path is not relative to parent, return absolute path
        return str(file_path)


def _format_table(table_name: str, headers: tuple[str, ...], rows: list[tuple[str | int, ...]], align: tuple[str, ...] | None = None) -> str:
    """Format data as an aligned table with centered table name.

    Creates a formatted table with a centered table name, column headers, separator line, and aligned data rows. Supports left
    and right alignment per column. Auto-detects alignment based on data types if not specified (integers right-aligned,
    strings left-aligned).

    Args:
        table_name: Name of the table, centered above the table.
        headers: Column header names.
        rows: List of row data tuples. Each tuple contains values for one row.
        align: Alignment per column ('left' or 'right'). If None, auto-detects based on first row data types.

    Returns:
        str: Formatted table string with centered name, headers, separator, and aligned rows. Empty string if no rows.
    """
    if not rows:
        return ''
    # Auto-detect alignment if not provided
    if align is None:
        align = tuple('right' if isinstance(rows[0][i], int) else 'left' for i in range(len(headers)))
    # Calculate column widths (max of header width and data width)
    col_widths = [len(str(h)) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            col_widths[i] = max(col_widths[i], len(str(cell)))
    # Calculate total table width (column widths + separators)
    table_width = sum(col_widths) + (len(col_widths) - 1) * 2  # 2 spaces between columns
    # Center table name over the table
    lines = []
    lines.append(table_name.center(table_width))
    # Build header line
    header_parts = []
    separator_parts = []
    for i, (header, width) in enumerate(zip(headers, col_widths)):
        if align[i] == 'right':
            header_parts.append(str(header).rjust(width))
        else:
            header_parts.append(str(header).ljust(width))
        separator_parts.append('-' * width)
    lines.append('  '.join(header_parts))
    lines.append('  '.join(separator_parts))
    # Build data rows
    for row in rows:
        row_parts = []
        for i, (cell, width) in enumerate(zip(row, col_widths)):
            if align[i] == 'right':
                row_parts.append(str(cell).rjust(width))
            else:
                row_parts.append(str(cell).ljust(width))
        lines.append('  '.join(row_parts))
    return '\n'.join(lines)


def _format_file_results(occurrences: list[IgnoreOccurrence]) -> str:
    """Format detailed results grouped by file.

    Groups occurrences by file path and displays each file's suppressions sorted by line number. For each suppression, shows line
    number, tool name, error codes, and code context. Returns message if no suppressions found.

    Args:
        occurrences (list[IgnoreOccurrence]): List of all IgnoreOccurrence objects to format.

    Returns:
        str: Formatted string with detailed results ready to print.
    """
    if not occurrences:
        return 'No linter suppressions found.'
    lines = []
    # Sort occurrences by file_path first
    sorted_occurrences = sorted(occurrences, key=lambda x: x.file_path)
    # Group by file and format
    for file_path, file_occurrences in groupby(sorted_occurrences, key=lambda x: x.file_path):
        # Convert iterator to list and sort by line number
        occurrence_list = list(file_occurrences)
        # Get display_path from first occurrence (all occurrences for same file have same display_path)
        display_path = occurrence_list[0].display_path
        rows = []
        for occurrence in sorted(occurrence_list, key=lambda x: x.line_number):
            tool_display = _format_tool_name(occurrence.tool)
            error_codes_display = ', '.join(occurrence.error_codes)
            context = occurrence.line_content.strip()
            rows.append((occurrence.line_number, tool_display, error_codes_display, context))
        table = _format_table('File: %s' % (display_path), ('Line', 'Tool', 'Error Codes', 'Context'), rows, ('right', 'left', 'left', 'left'))
        lines.append('\n%s' % (table))
    return '\n'.join(lines)


def _format_statistics_by_tool(stats: Statistics) -> str:
    """Format statistics grouped by linter tool.

    Displays suppression counts and percentages for each linter tool, sorted by frequency (highest first). Useful for
    identifying which linters are most frequently suppressed in the codebase.

    Args:
        stats (Statistics): Statistics object containing computed metrics including ignores_by_tool distribution.

    Returns:
        str: Formatted statistics by tool string, or empty string if no data.
    """
    if not stats.ignores_by_tool:
        return ''
    sorted_tools = sorted(stats.ignores_by_tool.items(), key=operator.itemgetter(1), reverse=True)
    rows = []
    for tool, count in sorted_tools:
        tool_display = _format_tool_name(tool)
        percentage = round((count / stats.total_ignores * 100)) if stats.total_ignores > 0 else 0
        rows.append((tool_display, count, percentage))
    return '\n%s' % (_format_table('Statistics by Linter Tool', ('Tool', 'Count', 'Percentage'), rows, ('left', 'right', 'right')))


def _format_statistics_by_error_code(stats: Statistics) -> str:
    """Format statistics grouped by error code.

    Displays all suppressed error codes with counts and percentages, sorted by frequency (highest first). Helps identify which
    specific linter rules are most commonly ignored.

    Args:
        stats (Statistics): Statistics object containing computed metrics including ignores_by_error_code distribution.

    Returns:
        str: Formatted statistics by error code string, or empty string if no data.
    """
    if not stats.ignores_by_error_code:
        return ''
    sorted_codes = sorted(stats.ignores_by_error_code.items(), key=operator.itemgetter(1), reverse=True)
    rows = []
    for error_code, count in sorted_codes:
        percentage = round((count / stats.total_ignores * 100)) if stats.total_ignores > 0 else 0
        rows.append((error_code, count, percentage))
    return '\n%s' % (_format_table('Statistics by Error Code', ('Error Code', 'Count', 'Percentage'), rows, ('left', 'right', 'right')))


def _format_statistics_by_file(stats: Statistics) -> str:
    """Format statistics showing files with suppressions.

    Displays all files with suppressions, sorted by count (highest first). Helps identify files that may need refactoring or
    cleanup to reduce technical debt.

    Args:
        stats (Statistics): Statistics object containing computed metrics including ignores_per_file counts.

    Returns:
        str: Formatted statistics by file string, or empty string if no data.
    """
    if not stats.ignores_per_file:
        return ''
    sorted_files = sorted(stats.ignores_per_file.items(), key=operator.itemgetter(1), reverse=True)
    rows = [(count, stats.file_display_paths[file_path]) for file_path, count in sorted_files]
    return '\n%s' % (_format_table('Statistics by File', ('Count', 'File'), rows, ('right', 'left')))


def _format_overall_summary(stats: Statistics) -> str:
    """Format overall summary statistics.

    Displays comprehensive summary including: total files scanned, files with/without ignores, coverage percentage, total
    ignores, average ignores per file, and min/max distribution. Provides high-level overview of suppression usage across the
    codebase.

    Args:
        stats (Statistics): Statistics object containing computed metrics for summary generation.

    Returns:
        str: Formatted overall summary string.
    """
    rows = []
    rows.append(('Total Python files scanned', stats.total_files_scanned))
    rows.append(('Files with ignores', stats.files_with_ignores))
    rows.append(('Files without ignores', stats.total_files_scanned - stats.files_with_ignores))
    if stats.total_files_scanned > 0:
        percentage = round(stats.files_with_ignores / stats.total_files_scanned * 100)
        rows.append(('Percentage of files with ignores', '%d%%' % (percentage)))
    rows.append(('Total ignores found', stats.total_ignores))
    if stats.files_with_ignores > 0:
        avg_ignores = round(stats.total_ignores / stats.files_with_ignores)
        rows.append(('Average ignores per file (with ignores)', avg_ignores))
    if stats.ignores_per_file:
        max_ignores = max(stats.ignores_per_file.values())
        min_ignores = min(stats.ignores_per_file.values())
        rows.append(('Max ignores in single file', max_ignores))
        rows.append(('Min ignores in single file', min_ignores))
    return '\n%s' % (_format_table('Overall Summary', ('Metric', 'Value'), rows, ('left', 'right')))


def _format_statistics(stats: Statistics) -> str:
    """Format all statistics sections.

    Orchestrates formatting of all statistics sections in order: by tool, by error code, by file, and overall summary. Provides
    comprehensive statistical report for code quality analysis.

    Args:
        stats (Statistics): Statistics object containing all computed metrics for report generation.

    Returns:
        str: Formatted statistics string ready to print.
    """
    sections = (
        _format_statistics_by_tool(stats),
        _format_statistics_by_error_code(stats),
        _format_statistics_by_file(stats),
        _format_overall_summary(stats),
    )
    # Filter out empty sections
    non_empty_sections = [s for s in sections if s]
    return '\n'.join(non_empty_sections)


# #############################################################################################################################
# Argument Parsing
# #############################################################################################################################
def _get_args() -> argparse.Namespace:
    """Parse and validate command-line arguments for the linter_ignores_report script.

    Configures argument parser with path (-p/--path) and debug (-d/--debug) options. Validates that the specified path exists
    before returning parsed arguments. Exits with error message if path validation fails.

    Returns:
        argparse.Namespace: Parsed arguments containing the target path and logging options (path, debug).
    """
    parser = argparse.ArgumentParser(
        description='Analyze Python files for pre-commit linter suppression comments.',
        epilog='Examples:\n'
        '  %(prog)s -p ~/projects/myproject/src/main.py        # Scan single file\n'
        '  %(prog)s -p ~/projects/myproject                    # Scan directory recursively\n'
        '  %(prog)s -p ~/projects/myproject/src -d             # Scan with debug logging\n',
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    # Required arguments
    required_group = parser.add_argument_group('Required Arguments', 'Arguments that must be specified')
    required_group.add_argument('-p', '--path', type=str, dest='path', metavar='<path>', required=True,
                                help='path to a Python file or directory to scan for linter suppression comments')
    # Optional arguments
    optional_group = parser.add_argument_group('Optional Arguments', 'Arguments to control logging and output')
    optional_group.add_argument('-d', '--debug', action='store_true', dest='debug', default=False,
                                help='enable debug logging for verbose output (default: %(default)s)')
    args = parser.parse_args()
    # Validate path exists
    path = Path(args.path)
    if not path.exists():
        parser.error('Path does not exist: %s' % (path))
    return args


# #############################################################################################################################
# Main Function
# #############################################################################################################################
def main() -> None:
    """Main entry point for the linter_ignores_report script.

    Orchestrates the entire process: argument parsing, logging setup, file discovery, scanning, statistics calculation, and
    output display. Exits with code 1 if no Python files found at specified path. Uses debug logging when -d/--debug flag
    provided to show detailed execution information including resolved paths, file counts, and occurrence counts.
    """
    # Parse command-line arguments
    args = _get_args()
    # Configure logging
    setup_logging(enable_debug=args.debug)
    target_path = Path(args.path).resolve()
    get_logger().debug('Target path resolved to: %s', target_path)
    # Find all Python files
    python_files = _find_python_files(target_path)
    if not python_files:
        get_logger().error('No Python files found at: %s', target_path)
        sys.exit(1)
    get_logger().debug('Found %d Python file(s) to scan', len(python_files))
    # Scan all files for suppressions
    occurrences = _scan_all_files(python_files, target_path)
    get_logger().debug('Found %d total ignore occurrence(s)', len(occurrences))
    # Calculate statistics
    stats = _calculate_statistics(occurrences, len(python_files))
    # Display results with section headers
    print(_format_section_header('DETAILED RESULTS'))
    print(_format_file_results(occurrences))
    print('\n%s' % (_format_section_header('STATISTICS')))
    print(_format_statistics(stats))


# #############################################################################################################################
# Run main()
# #############################################################################################################################
if __name__ == '__main__':
    main()
