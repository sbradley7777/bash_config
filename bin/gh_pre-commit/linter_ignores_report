#!/usr/bin/env python3
"""Analyze Python files for pre-commit linter suppression comments.

This script scans Python files to identify all inline and file-level suppression comments used by pre-commit linters and
provides detailed statistics about their usage.

Supported Linters:
    This tool currently analyzes suppression comments for Python linters only. Based on typical pre-commit configurations,
    the following linters are detected:

    - flake8 (and plugins): Detects '# noqa:' comments with error codes (E501, DUO, SCS, CCR, ECE, TAE, MDA, etc.)
    - ruff: Detects both '# noqa:' and '# ruff: noqa:' comment styles
    - pydoclint: Detects '# noqa: DOC' comments for docstring violations
    - pylint: Detects '# pylint: disable=' comments with error codes or error names
    - mypy: Detects '# type: ignore' comments with optional error types in brackets
    - refurb: Detects both '# refurb: ignore' and '# noqa: FURB' comment styles
    - vulture: Detects '# noqa: F841' (unused variable) and '# noqa: F401' (unused import) comments

    Note: vulture uses flake8's noqa syntax rather than having its own ignore format, so vulture suppressions are
    reported as 'flake8' in the statistics.

The tool helps identify where code quality checks are being suppressed, allowing developers to review and potentially address
underlying issues rather than hiding them. This is particularly useful for:
- Code quality audits to identify technical debt
- Refactoring efforts to reduce reliance on suppressions
- Understanding which linter rules are most commonly suppressed
- Identifying files with excessive suppressions that may need cleanup

This is a read-only analysis tool - it does not modify any files.

Entry Point:
    This module can be executed directly:
    - Direct execution: linter_ignores_report

Manual Usage:
    Scan a single Python file:
        $ linter_ignores_report -p /path/to/file.py

    Scan a directory recursively:
        $ linter_ignores_report -p ~/projects/myproject

    Scan multiple files using shell expansion:
        $ linter_ignores_report -p ~/projects/myproject/src

    Enable debug logging for troubleshooting:
        $ linter_ignores_report -p ~/projects/myproject -d

Output:
    - Detailed list of all ignores found (file, line number, type, context)
    - Statistics by linter tool (which tools are most frequently suppressed)
    - Statistics by error code (which specific errors are most commonly ignored)
    - Top files with most ignores (files that may need refactoring)
    - Overall summary metrics (coverage, averages, distribution)

Requirements:
    - Python 3.12+
    - Read access to target files/directories
"""
# pylint: disable=W8201
from __future__ import annotations

import argparse
import logging
import operator
import re
import sys
from collections import defaultdict
from itertools import groupby
from logging import StreamHandler
from pathlib import Path
from typing import TYPE_CHECKING, ClassVar

if TYPE_CHECKING:
    from collections.abc import Sequence

# #############################################################################################################################
# Constants
# #############################################################################################################################
#: The root logger name for the application
ROOT_LOGGER_NAME: str = 'linter_ignores_report'
#: The name of the stream handler for the logger
STREAM_HANDLER_NAME: str = 'stream_handler'
#: Colored log format (brackets added by ColoredFormatter)
LOG_FORMAT_COLORED: str = '%(levelname)s%(message)s'
"""Regex patterns for detecting linter suppression comments in Python files.

Some linters accept error codes (E501, C0103), error names (invalid-name), or both.  Not all linters support both formats -
consult individual linter documentation.

Examples of linter suppression formats detected by this script

flake8/ruff noqa:
    # noqa                           (suppress all errors on this line)
    # noqa: E501                     (suppress specific error code E501)
    # noqa: E501,F841                (suppress multiple error codes)

mypy type-ignore:
    # type: ignore                   (suppress all type errors on this line)
    # type: ignore[attr-defined]     (suppress specific error type)
    # type: ignore[arg-type,return-value]  (suppress multiple error types)

pylint:
    # pylint: disable=invalid-name   (suppress using error name)
    # pylint: disable=C0103           (suppress using error code)
    # pylint: disable=C0103,W0613     (suppress multiple errors)
    Note: Pylint accepts BOTH error codes (C0103) AND error names (invalid-name)

ruff:
    # ruff: noqa                     (suppress all ruff errors on this line)
    # ruff: noqa: E501               (suppress specific error code)
    # ruff: noqa: E501,F841          (suppress multiple error codes)

refurb:
    # refurb: ignore                 (suppress all refurb suggestions on this line)
    # refurb: ignore[FURB123]        (suppress specific suggestion code)
    # refurb: ignore[FURB123,FURB456]  (suppress multiple suggestions)
"""
IGNORE_PATTERNS = {
    'noqa': re.compile(r'#\s*noqa(?::\s*([A-Z0-9,\s]+))?'),
    'type-ignore': re.compile(r'#\s*type:\s*ignore(?:\[([^\]]+)\])?'),
    'pylint': re.compile(r'#\s*pylint:\s*disable=([A-Za-z0-9,\s\-]+)'),
    'ruff-noqa': re.compile(r'#\s*ruff:\s*noqa(?::\s*([A-Z0-9,\s]+))?'),
    'refurb': re.compile(r'#\s*refurb:\s*ignore(?:\[([^\]]+)\])?'),
}


# #############################################################################################################################
# Logging Classes
# #############################################################################################################################
class ColoredFormatter(logging.Formatter):
    """Formatter that colorizes log output using ANSI escape codes.

    This follows the Python community standard pattern for colored logging: colorization happens in the Formatter.format()
    method by wrapping the format string with ANSI color codes based on the log level.

    Args:
        fmt (str): The log format string (e.g., '%(levelname)s %(message)s').
        bold (bool): Whether to make the output bold. Defaults to True.

    Attributes:
        ESCAPE_CODE (str): ANSI escape code prefix.
        ESCAPE_CODE_END (str): ANSI escape code suffix.
        RESET (str): ANSI reset code to clear formatting.
        BOLD (str): ANSI bold modifier code.
        COLORS (ClassVar[dict[str, int]]): Mapping of color names to ANSI codes.
        LEVEL_COLORS (ClassVar[dict[int, str]]): Mapping of log levels to color names.
    """
    ESCAPE_CODE: str = '\033['
    ESCAPE_CODE_END: str = 'm'
    RESET: str = '%s0%s' % (ESCAPE_CODE, ESCAPE_CODE_END)
    BOLD: str = '01'
    COLORS: ClassVar[dict[str, int]] = {
        'black': 30, 'red': 31, 'green': 32, 'yellow': 33, 'blue': 34, 'magenta': 35, 'cyan': 36,
        'light_grey': 37, 'dark_grey': 90, 'light_red': 91, 'light_green': 92, 'light_yellow': 93,
        'light_blue': 94, 'light_magenta': 95, 'light_cyan': 96, 'white': 97
    }
    LEVEL_COLORS: ClassVar[dict[int, str]] = {
        logging.DEBUG: 'magenta',
        logging.INFO: 'blue',
        logging.WARNING: 'yellow',
        logging.ERROR: 'red',
        logging.CRITICAL: 'green',
    }

    def __init__(self, fmt: str, bold: bool = True) -> None:
        super().__init__()
        self.fmt = fmt
        self.bold = bold

    def _get_color_code(self, color_name: str) -> int:
        """Get ANSI color code from color name.

        Args:
            color_name (str): Color name (e.g., 'red', 'blue').

        Returns:
            int: The ANSI color code.
        """
        return self.COLORS.get(color_name, 37)

    def _calculate_levelname_padding(self, bracketed_levelname: str) -> int:
        """Calculate padding needed to align all log level names.

        Args:
            bracketed_levelname (str): Level name with brackets (e.g., '[WARNING]').

        Returns:
            int: Number of spaces needed to reach alignment width.
        """
        all_levels = ('DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL')
        max_width = max(len('[%s]' % (level)) for level in all_levels) + 1
        return max(0, max_width - len(bracketed_levelname))

    def _colorize_levelname(self, levelname: str, levelno: int) -> str:
        """Colorize a log level name with brackets and padding using ANSI escape codes.

        Args:
            levelname (str): The log level name (e.g., 'WARNING').
            levelno (int): The logging level number (e.g., logging.WARNING).

        Returns:
            str: The colorized level name with brackets and padding (e.g., '[WARNING] ').
        """
        color_name = self.LEVEL_COLORS.get(levelno, 'light_grey')
        color_code = self._get_color_code(color_name)
        if self.bold:
            ansi_start = '%s%s;%d%s' % (self.ESCAPE_CODE, self.BOLD, color_code, self.ESCAPE_CODE_END)
        else:
            ansi_start = '%s%d%s' % (self.ESCAPE_CODE, color_code, self.ESCAPE_CODE_END)
        bracketed_levelname = '[%s]' % (levelname)
        padding_needed = self._calculate_levelname_padding(bracketed_levelname)
        padded_text = '%s%s' % (bracketed_levelname, ' ' * padding_needed)
        return '%s%s%s' % (ansi_start, padded_text, self.RESET)

    def format(self, record: logging.LogRecord) -> str:
        """Format log record with colorized level name only.

        Args:
            record (logging.LogRecord): The log record to format.

        Returns:
            str: Formatted log message with colorized level name only.
        """
        original_levelname = record.levelname
        record.levelname = self._colorize_levelname(original_levelname, record.levelno)
        result = logging.Formatter(self.fmt).format(record)
        record.levelname = original_levelname
        return result


